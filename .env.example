# --- File format (product-specific) -----------------------------------------
# Docs deployments set .docx; Sheets deployments use the default .xlsx.
CASUAL_FILE_EXT=.xlsx
# Optional explicit override; derived from CASUAL_FILE_EXT when unset.
# CASUAL_FILE_CONTENT_TYPE=application/vnd.openxmlformats-officedocument.wordprocessingml.document

# --- Storage backend --------------------------------------------------------
# memory (default, ephemeral) | local | s3 | postgres
CASUAL_STORAGE=memory

# local
CASUAL_LOCAL_PATH=/data

# postgres
# CASUAL_PG_URL=postgres://user:pass@host:5432/db
# CASUAL_PG_TABLE=casual_workbooks

# s3 / minio / r2 / b2
# CASUAL_S3_BUCKET=
# CASUAL_S3_REGION=us-east-1
# CASUAL_S3_ENDPOINT=
# CASUAL_S3_ACCESS_KEY=
# CASUAL_S3_SECRET_KEY=
# CASUAL_S3_FORCE_PATH_STYLE=false
# CASUAL_S3_KEY_PREFIX=

# --- Auth / cookies ---------------------------------------------------------
# SECURE_COOKIES=true
# JWT / WOPI vars as used by the deployment
